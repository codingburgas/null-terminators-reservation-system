glfw/build/
glfw/CMakeFiles/

# ─── OpenGL / Graphics drivers ───────────────────────────────────────────────
*.glsl.spv

# ─── Compiler / Linker Intermediates ─────────────────────────────────────────
*.map
*.lst
*.asm

